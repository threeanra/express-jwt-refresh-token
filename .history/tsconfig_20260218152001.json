{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": ".",              
    "paths": {
      "@prisma": ["src/generated/prisma"],
      "@/*": ["src/*"]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}
