generator client {
  provider = "prisma-client-id"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String    @id @db.VarChar(26)
  email        String    @unique
  password     String
  refreshToken String?   @db.Text
  products     Product[]
}

model Product {
  id        String   @id @db.VarChar(26)
  name      String
  price     Int
  userId    String   @db.VarChar(26)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
