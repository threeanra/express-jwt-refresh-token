{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": ".",              // ⬅️ WAJIB ADA
    "paths": {
      "@prisma": ["src/generated/prisma"],
      "@/*": ["src/*"]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}
